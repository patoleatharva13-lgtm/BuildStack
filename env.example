# Copy this file to `.env` and fill in your keys.

# --- Supabase (get from https://app.supabase.com > Project Settings > API) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...

# --- Groq AI (get from https://console.groq.com/keys) ---
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Resend (get from https://resend.com/api-keys) ---
# Used by the /api/resend/emails.js serverless function (Vercel/Netlify).
# For local Vite development, you can also set VITE_RESEND_API_KEY and VITE_RESEND_FROM_EMAIL.
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
VITE_RESEND_API_KEY=re_your_resend_api_key_here
VITE_RESEND_FROM_EMAIL=onboarding@resend.dev


